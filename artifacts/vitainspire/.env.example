# Google Drive bridge (GAS Web App URL — deployed from gas/DriveBridge.js)
EXPO_PUBLIC_GAS_BRIDGE_URL=https://script.google.com/macros/s/YOUR_DRIVE_DEPLOYMENT_ID/exec

# Google Drive root folder ID (the folder where photos are uploaded)
EXPO_PUBLIC_DRIVE_FOLDER_ID=YOUR_DRIVE_FOLDER_ID

# Google Sheets bridge (GAS Web App URL — deployed from gas/SheetBridge.js, container-bound)
EXPO_PUBLIC_SHEET_BRIDGE_URL=https://script.google.com/macros/s/YOUR_SHEET_DEPLOYMENT_ID/exec

# Google Sheet ID (optional — only needed if using standalone GAS deployment)
EXPO_PUBLIC_SHEET_ID=YOUR_SHEET_ID
